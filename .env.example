# ─── App ──────────────────────────────────────────
# Bind to loopback by default; expose publicly via Cloudflare Tunnel only.
APP_HOST=127.0.0.1
APP_PORT=8000
# REQUIRED: generate a strong random value, e.g. `openssl rand -hex 32`
API_KEY=change_me_strong_secret
LOG_LEVEL=INFO
TZ=UTC
APP_LANG=EN
CODE_LENGTH=6
# true = mask entered digits as ***, false = show digits on the display
MASK_CODE_INPUT=false

# ─── Display ──────────────────────────────────────
DISPLAY_IDLE_TEXT=AllDigital
DISPLAY_IDLE_SUBTEXT=Welcome

# ─── Hardware ─────────────────────────────────────
RELAY_ACTIVE_LOW=true
DOOR_RELAY_GPIO=17
DOOR_UNLOCK_DURATION=5

EXIT_BUTTON_GPIO=26

BUZZER_GPIO=24
BUZZER_ENABLED=true

LIGHT_RELAY_1_GPIO=27
LIGHT_RELAY_2_GPIO=22

KEYPAD_ROW_PINS=5,6,13,19
KEYPAD_COL_PINS=12,16,20

# ─── Cloudflare Tunnel ────────────────────────────
CF_TUNNEL_TOKEN=
CF_TUNNEL_NAME=padel-access
